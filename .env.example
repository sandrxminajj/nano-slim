# ============================================================
# Nano Slim — Variáveis de Ambiente
# ============================================================
# Copia este ficheiro para .env (NUNCA commitar .env)
# OU adiciona estas variáveis no Vercel dashboard:
#    Settings -> Environment Variables
# ============================================================

# --- WayMB Payment Gateway (OBRIGATÓRIAS) ---
# Pedir credenciais em https://waymb.com
WAYMB_CLIENT_ID=
WAYMB_CLIENT_SECRET=
WAYMB_ACCOUNT_EMAIL=

# --- Opcional: domínio custom para webhook ---
# Só preencher se tiveres domínio próprio (ex: https://nano-slim.pt/api/webhook)
# Se ficar vazio, auto-detecta via VERCEL_URL.
# CALLBACK_URL=
